# ==========================================================
# MedSest Visita — variáveis de ambiente (EXEMPLO)
# Copie para .env e preencha com valores reais.
# NUNCA versione o arquivo .env com valores reais.
# ==========================================================

# --- Banco de dados ---
# Dev local (docker-compose): usuário/senha do docker-compose.yml
DATABASE_URL=postgresql+asyncpg://medsest_user:medsest_dev_password@localhost:5432/medsest_db

# --- Segurança / JWT ---
SECRET_KEY=troque-por-uma-chave-secreta-de-no-minimo-32-caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# --- URLs / validação do cliente ---
APP_BASE_URL=http://localhost:5173
VALIDACAO_TOKEN_EXPIRE_DAYS=7

# --- E-mail (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contato@medsest.com.br
SMTP_PASSWORD=senha-app-google
SMTP_FROM_NAME=MedSest Visita

# --- WhatsApp (Twilio) ---
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Ambiente ---
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]
